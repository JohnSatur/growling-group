---
import '@styles/global.css';
import Meta from '@components/layout/Meta.astro';
import { SITE } from '@data/constants';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

interface Props {
	title?: string;
	lang?: string;
	palette?: 'cardinal' | 'ambiental' | 'drones' | 'calderas' | 'civil' | 'capacitacion' | 'gubernamental';
}

const {
	title = SITE.title,
	lang = 'es-MX',
	palette = 'cardinal',
}: Props = Astro.props;
---

<!DOCTYPE html>
<html lang={ lang }>
	<head>
		<Meta />
		<title>{ title }</title>
		<script is:inline>
			// Detectar y aplicar el tema antes de que se cargue la página para evitar flash
			(function() {
				const getStoredTheme = () => localStorage.getItem('theme');
				const getPreferredTheme = () => {
					const storedTheme = getStoredTheme();
					if (storedTheme) {
						return storedTheme;
					}
					// Si no hay preferencia guardada, usar la preferencia del sistema
					return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				};

				const theme = getPreferredTheme();
				document.documentElement.classList.add(theme);
				
				// Guardar el tema inicial si no existe
				if (!getStoredTheme()) {
					localStorage.setItem('theme', theme);
				}
			})();
		</script>
	</head>
	<body class="font-contrast bg-background">
		<Header palette={palette} />
		<slot />
		<Footer palette={palette} />
	</body>
</html>
