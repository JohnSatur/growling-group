---
import { OG, SEO, SITE } from '@data/constants';
import { getImage } from 'astro:assets';
import favicon from '/favicon.ico';

const defaultProps = {
  meta: SITE.description,
  structuredData: SEO.stucturedData,
};

const {
  meta = defaultProps.meta,
  structuredData = defaultProps.structuredData,
} = Astro.props;

const author = SITE.author;
// TODO: Obtener la URL del sitio
const URL = `${Astro.site}`;
const canonical = Astro.url.pathname;
const ogTitle = OG.title;
const ogDescription = OG.description;
const socialImageRes = await getImage({
  src: OG.image,
  width: 1080,
  height: 1080,
});
const socialImage = Astro.url.origin + socialImageRes.src;

---

{
  structuredData && (
    <script type="application/ld+json">
      {JSON.stringify(structuredData)}
    </script>
  )
}

<!-- General Meta -->
<meta charset="utf-8" />
<meta content={meta} name="description" />
<meta name="web_author" content={author} />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=3.0, minimum-scale=1.0" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="generator" content={Astro.generator} />

<!-- Facebook Meta Tags -->
<meta property="og:locale" content="es_MX" />
<meta property="og:url" content={URL} />
<meta property="og:type" content="website" />
<meta property="og:title" content={ogTitle} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={socialImage} />
<meta content="1200" property="og:image:width" />
<meta content="600" property="og:image:height" />
<meta content="image/png" property="og:image:type" />

<!-- TODO: Hacer un sitemap -->
<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Twitter Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:domain" content={URL} />
<meta name="twitter:url" content={URL} />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={socialImage} />

<!-- Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

<!-- Remixicon -->
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
