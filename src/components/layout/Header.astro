---
import Button from '@components/ui/Button.astro';
import Logo from '@components/ui/Logo.astro';
import isotipo from '@images/isotipo.png';
import { Image } from 'astro:assets';

interface Props {
	palette?: 'cardinal' | 'ambiental' | 'drones' | 'calderas' | 'civil' | 'capacitacion' | 'gubernamental';
}

const { palette = 'cardinal' }: Props = Astro.props;

// Definir clases de colores basadas en la palette
const colorClasses = {
  cardinal: {
    hover: 'hover:text-cardinal',
    text: 'text-cardinal',
    bg: 'bg-cardinal',
    border: 'border-cardinal bg-cardinal'
  },
  ambiental: {
    hover: 'hover:text-ambiental',
    text: 'text-ambiental',
    bg: 'bg-ambiental',
    border: 'border-ambiental bg-ambiental'
  },
  drones: {
    hover: 'hover:text-drones',
    text: 'text-drones',
    bg: 'bg-drones',
    border: 'border-drones bg-drones'
  },
  calderas: {
    hover: 'hover:text-calderas',
    text: 'text-calderas',
    bg: 'bg-calderas',
    border: 'border-calderas bg-calderas'
  },
  civil: {
    hover: 'hover:text-civil',
    text: 'text-civil',
    bg: 'bg-civil',
    border: 'border-civil bg-civil'
  },
  capacitacion: {
    hover: 'hover:text-capacitacion',
    text: 'text-capacitacion',
    bg: 'bg-capacitacion',
    border: 'border-capacitacion bg-capacitacion'
  },
  gubernamental: {
    hover: 'hover:text-gubernamental',
    text: 'text-gubernamental',
    bg: 'bg-gubernamental',
    border: 'border-gubernamental bg-gubernamental'
  }
};

const colors = colorClasses[palette];
---

<header class="fixed top-0 left-0 w-full bg-dark bg-opacity-95 z-50 shadow-sm transition-all duration-300 border-b border-neutral-400">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0">
        <!-- Logo placeholder -->
        <a href="/" class="flex items-center">
          <Logo palette={palette} variant="isotipo" class="w-10 h-full object-contain" />
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class={`text-slate-100 ${colors.hover} font-medium transition-colors duration-300 relative group`}>
          Inicio
          <span class={`absolute bottom-0 left-0 w-0 h-0.5 ${colors.bg} transition-all duration-300 group-hover:w-full`}></span>
        </a>
        <a href="/quienes-somos" class={`text-slate-100 ${colors.hover} font-medium transition-colors duration-300 relative group`}>
          Quiénes somos
          <span class={`absolute bottom-0 left-0 w-0 h-0.5 ${colors.bg} transition-all duration-300 group-hover:w-full`}></span>
        </a>
        
        <!-- Servicios Dropdown Desktop -->
        <div class="relative group">
          <button class={`text-slate-100 ${colors.hover} font-medium transition-colors duration-300 relative flex items-center gap-1`}>
            Servicios
            <i class="ri-arrow-down-s-line text-sm transition-transform duration-300 group-hover:rotate-180"></i>
            <span class={`absolute bottom-0 left-0 w-0 h-0.5 ${colors.bg} transition-all duration-300 group-hover:w-full`}></span>
          </button>
          <div class="absolute top-full left-0 mt-2 w-64 bg-dark bg-opacity-98 rounded-lg shadow-lg border border-neutral-600 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <div class="py-2">
              <a href="/servicios-ambientales" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Servicios ambientales
              </a>
              <a href="/proteccion-civil-veracruz" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Protección civil (Veracruz)
              </a>
              <a href="/calderas-y-recipientes-a-presion" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Calderas y recipientes a presión
              </a>
              <a href="/inspeccion-drones" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Inspección con drones
              </a>
              <a href="/capacitacion-certificada" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Capacitación certificada
              </a>
              <a href="/tramites-gubernamentales" class={`block px-4 py-3 text-slate-100 ${colors.hover} hover:bg-neutral-800 transition-colors duration-300`}>
                Trámites gubernamentales
              </a>
            </div>
          </div>
        </div>
        
        <a href="/blog" class={`text-slate-100 ${colors.hover} font-medium transition-colors duration-300 relative group`}>
          Blog
          <span class={`absolute bottom-0 left-0 w-0 h-0.5 ${colors.bg} transition-all duration-300 group-hover:w-full`}></span>
        </a>
        <a href="/contacto" class={`text-slate-100 ${colors.hover} font-medium transition-colors duration-300 relative group`}>
          Contacto
          <span class={`absolute bottom-0 left-0 w-0 h-0.5 ${colors.bg} transition-all duration-300 group-hover:w-full`}></span>
        </a>
        <!-- Theme Toggle Button -->
        <button
          id="theme-toggle"
          type="button"
          class={`text-slate-100 ${colors.hover} focus:outline-none rounded-lg text-sm p-2.5 transition-colors duration-300`}
          aria-label="Toggle theme"
        >
          <i id="theme-toggle-dark-icon" class="hidden ri-moon-fill text-xl"></i>
          <i id="theme-toggle-light-icon" class="hidden ri-sun-fill text-xl"></i>
        </button>
      </nav>

      <!-- Mobile Navigation Button -->
      <div class="md:hidden flex items-center space-x-4">
        <!-- Theme Toggle Button for Mobile -->
        <button
          id="theme-toggle-mobile"
          type="button"
          class={`text-slate-50 ${colors.hover} rounded-lg text-sm p-2.5 transition-colors duration-300`}
          aria-label="Toggle theme"
        >
          <i id="theme-toggle-dark-icon-mobile" class="hidden ri-moon-fill text-xl"></i>
          <i id="theme-toggle-light-icon-mobile" class="hidden ri-sun-fill text-xl"></i>
        </button>
        <button id="mobile-menu-button" class={`text-slate-50 ${colors.hover} focus:outline-none cursor-pointer transition-colors duration-300`}>
          <i class="ri-menu-line text-2xl"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-dark bg-opacity-98 z-50 transform translate-x-full transition-transform duration-300 ease-in-out">
    <div class="h-full flex flex-col">
      <div class="flex justify-end p-4">
        <button id="mobile-menu-close" class={`text-slate-50 ${colors.hover} focus:outline-none cursor-pointer transition-colors duration-300`}>
          <i class="ri-close-line text-3xl"></i>
        </button>
      </div>
      
      <!-- Logo en móvil -->
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-center">
          <Logo palette={palette} variant="isotipo" class="w-16 h-full object-contain" />
        </a>
      </div>

      <nav class="flex-1 flex flex-col items-center justify-center space-y-6 px-4 overflow-y-auto">
        <a href="/" class={`text-slate-100 ${colors.hover} text-2xl font-medium transition-colors duration-300`}>
          Inicio
        </a>
        <a href="/quienes-somos" class={`text-slate-100 ${colors.hover} text-2xl font-medium transition-colors duration-300`}>
          Quiénes somos
        </a>
        
        <!-- Servicios Dropdown Mobile -->
        <div class="text-center flex flex-col items-center justify-center">
          <button id="mobile-servicios-toggle" class={`ml-7 text-slate-100 ${colors.hover} text-2xl font-medium transition-colors duration-300 flex items-center gap-2`}>
            Servicios
            <i id="mobile-servicios-icon" class="ri-arrow-down-s-line text-lg transition-transform duration-300"></i>
          </button>
          <div id="mobile-servicios-menu" class="space-y-3 max-h-0 overflow-hidden transition-all duration-300">
            <a href="/servicios-ambientales" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Servicios ambientales
            </a>
            <a href="#proteccion-civil" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Protección civil (Veracruz)
            </a>
            <a href="#calderas" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Calderas y recipientes a presión
            </a>
            <a href="/inspeccion-drones" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Inspección con drones
            </a>
            <a href="#capacitacion" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Capacitación certificada
            </a>
            <a href="#tramites" class={`block text-slate-300 ${colors.hover} text-lg transition-colors duration-300`}>
              Trámites gubernamentales
            </a>
          </div>
        </div>
        
        <a href="#blog" class={`text-slate-100 ${colors.hover} text-2xl font-medium transition-colors duration-300`}>
          Blog
        </a>
        <a href="#contacto" class={`text-slate-100 ${colors.hover} text-2xl font-medium transition-colors duration-300`}>
          Contacto
        </a>
      </nav>

      <!-- Botón CTA -->
      <div class="p-6 text-center">
        <Button 
          href="#contacto" 
          text="Solicita una cotización"
          icon="ri-wallet-2-fill"
          variant="fill"
          palette={palette}
        />
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu functionality
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const body = document.body;

  function toggleMobileMenu() {
    mobileMenu?.classList.toggle('translate-x-full');
    body.classList.toggle('overflow-hidden');
  }

  if (mobileMenuButton && mobileMenuClose && mobileMenu) {
    mobileMenuButton.addEventListener('click', toggleMobileMenu);
    mobileMenuClose.addEventListener('click', toggleMobileMenu);
  }

  // Mobile servicios dropdown functionality
  const mobileServiciosToggle = document.getElementById('mobile-servicios-toggle');
  const mobileServiciosMenu = document.getElementById('mobile-servicios-menu');
  const mobileServiciosIcon = document.getElementById('mobile-servicios-icon');

  if (mobileServiciosToggle && mobileServiciosMenu && mobileServiciosIcon) {
    mobileServiciosToggle.addEventListener('click', () => {
      const isOpen = mobileServiciosMenu.style.maxHeight && mobileServiciosMenu.style.maxHeight !== '0px';
      
      if (isOpen) {
        mobileServiciosMenu.style.maxHeight = '0px';
        mobileServiciosIcon.classList.remove('rotate-180');
      } else {
        mobileServiciosMenu.style.maxHeight = mobileServiciosMenu.scrollHeight + 'px';
        mobileServiciosIcon.classList.add('rotate-180');
        mobileServiciosToggle.classList.add('mb-4');
      }
    });
  }

  // Header scroll behavior
  const header = document.querySelector('header');
  
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 0) {
        header.classList.add('shadow-md');
        header.classList.add('bg-opacity-98');
      } else {
        header.classList.remove('shadow-md');
        header.classList.remove('bg-opacity-98');
      }
    });
  }

  // Theme toggle functionality
  const themeToggleBtn = document.getElementById('theme-toggle');
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
  const themeToggleBtnMobile = document.getElementById('theme-toggle-mobile');
  const themeToggleDarkIconMobile = document.getElementById('theme-toggle-dark-icon-mobile');
  const themeToggleLightIconMobile = document.getElementById('theme-toggle-light-icon-mobile');

  // Función para actualizar los iconos basados en el tema actual
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    
    if (isDark) {
      themeToggleLightIcon?.classList.remove('hidden');
      themeToggleDarkIcon?.classList.add('hidden');
      themeToggleLightIconMobile?.classList.remove('hidden');
      themeToggleDarkIconMobile?.classList.add('hidden');
    } else {
      themeToggleDarkIcon?.classList.remove('hidden');
      themeToggleLightIcon?.classList.add('hidden');
      themeToggleDarkIconMobile?.classList.remove('hidden');
      themeToggleLightIconMobile?.classList.add('hidden');
    }
  }

  // Inicializar iconos basados en el tema actual
  updateThemeIcons();

  function toggleTheme() {
    const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

    // Remover tema actual y aplicar nuevo tema
    document.documentElement.classList.remove('dark', 'light');
    document.documentElement.classList.add(newTheme);

    // Guardar la preferencia en localStorage
    localStorage.setItem('theme', newTheme);

    // Actualizar iconos
    updateThemeIcons();
  }

  // Add click event listeners
  themeToggleBtn?.addEventListener('click', toggleTheme);
  themeToggleBtnMobile?.addEventListener('click', toggleTheme);
</script>
