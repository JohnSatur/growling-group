---
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  title: string;
  excerpt: string;
  date: string;
  link?: string;
}

const { 
  image, 
  title, 
  excerpt, 
  date, 
  link = "#" 
} = Astro.props;
---

<div class="overflow-hidden bg-neutral-100 rounded-xl shadow-lg transition-all hover:shadow-xl">
  <div class="h-48 overflow-hidden">
    <Image 
      src={image}
      alt={title}
      width={612}
      height={344}
      class="w-full h-full object-cover transition-transform hover:scale-105 duration-500"
    />
  </div>
  <div class="p-6">
    <p class="text-sm text-cardinal-300 mb-2">{date}</p>
    <h3 class="text-xl font-semibold text-cardinal mb-3">{title}</h3>
    <p class="text-neutral-700 mb-4">{excerpt}</p>
    <a 
      href={link} 
      class="inline-flex items-center text-cardinal font-medium hover:text-cardinal/80 transition-colors"
    >
      Leer más
      <i class="ri-arrow-right-s-line ml-1"></i>
    </a>
  </div>
</div> 