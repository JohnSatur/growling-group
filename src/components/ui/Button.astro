---
export interface Props {
  text: string;
  href: string;
  variant?: 'fill' | 'outline';
  icon?: string;
  iconPosition?: 'left' | 'right';
  class?: string;
  palette?: 'cardinal' | 'ambiental' | 'drones' | 'calderas' | 'civil' | 'capacitacion' | 'gubernamental';
}

const { 
  text, 
  href, 
  variant = 'fill', 
  icon, 
  iconPosition = 'right',
  class: additionalClass = '',
  palette = 'cardinal'
} = Astro.props;

// Base classes
const baseClasses = "inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-150 py-4 px-8 text-base";

// Size variants
// const sizeClasses = {
//   sm: 'py-2 px-4 text-sm',
//   md: 'py-4 px-8 text-base',
//   lg: 'py-5 px-10 text-lg'
// };

// Style variants with explicit classes for each palette
const variantClasses = {
  fill: {
    cardinal: 'bg-cardinal/90 hover:bg-cardinal text-white hover:shadow-lg',
    ambiental: 'bg-ambiental/90 hover:bg-ambiental text-white hover:shadow-lg',
    drones: 'bg-drones/90 hover:bg-drones text-white hover:shadow-lg',
    calderas: 'bg-calderas/90 hover:bg-calderas text-white hover:shadow-lg',
    civil: 'bg-civil/90 hover:bg-civil text-white hover:shadow-lg',
    capacitacion: 'bg-capacitacion/90 hover:bg-capacitacion text-white hover:shadow-lg',
    gubernamental: 'bg-gubernamental/90 hover:bg-gubernamental text-white hover:shadow-lg',
  },
  outline: {
    cardinal: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    ambiental: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    drones: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    calderas: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    civil: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    capacitacion: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
    gubernamental: 'bg-transparent hover:bg-neutral-900 border-2 border-neutral-900 text-neutral-900 hover:text-neutral-50 hover:shadow-lg',
  },
  outline2: {
    cardinal: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    ambiental: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    drones: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    calderas: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    civil: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    capacitacion: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
    gubernamental: 'bg-transparent hover:bg-neutral-100 border-2 border-neutral-100 text-neutral-100 hover:text-neutral-950 hover:shadow-lg',
  }
};

// Combine all classes
const buttonClasses = `${baseClasses} ${variantClasses[variant][palette]} ${additionalClass}`;

// Icon classes
const iconClasses = icon ? (iconPosition === 'left' ? 'mr-2' : 'ml-2') + ' text-lg' : '';
---

<a href={href} class={buttonClasses}>
  {icon && iconPosition === 'left' && <i class={`${icon} ${iconClasses}`}></i>}
  {text}
  {icon && iconPosition === 'right' && <i class={`${icon} ${iconClasses}`}></i>}
</a>
