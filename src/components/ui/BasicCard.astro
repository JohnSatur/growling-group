---
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  title: string;
  description: string;
  link: string;
  linkText?: string;
}

const { 
  image, 
  title, 
  description, 
  link, 
  linkText = "Ver más"
} = Astro.props;
---

<div class="bg-neutral-100 border border-neutral-200 rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-xl">
  <div class="h-48 overflow-hidden">
    <Image 
      src={image}
      alt={title}
      width={612}
      height={344}
      class="w-full h-full object-cover transition-transform hover:scale-110 duration-300"
    />
  </div>
  <div class="p-6 flex flex-col gap-2">
    <div class="flex-1">
      <h3 class="text-xl font-semibold text-neutral-900 mb-3">{title}</h3>
      <p class="text-neutral-700">{description}</p>
    </div>
    <a href={link} class="inline-flex items-center text-cardinal font-medium hover:text-cardinal/80 transition-colors mt-4">
      {linkText} <i class="ri-arrow-right-s-line ml-1 text-base"></i>
    </a>
  </div>
</div>
