---
interface Props {
  quote: string;
  author: string;
  position: string;
}

const { quote, author, position } = Astro.props;
---

<div 
  class="bg-neutral-800 p-8 rounded-xl shadow-lg border-t-4 border-cardinal"
>
  <div class="mb-4 text-cardinal">
    <i class="ri-double-quotes-l text-4xl"></i>
  </div>
  <p class="text-neutral-300 mb-6 italic">"{quote}"</p>
  <div>
    <p class="font-semibold text-neutral-200">{author}</p>
    <p class="text-sm text-neutral-400">{position}</p>
  </div>
</div>
