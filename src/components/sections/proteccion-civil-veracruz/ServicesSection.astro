---
import Button from "@components/ui/Button.astro";

const services = [
  {
    id: 1,
    title: "Análisis de Riesgo y Vulnerabilidad (ARV)",
    description: "Evaluación integral de amenazas, vulnerabilidades y capacidades de respuesta. Identificamos riesgos potenciales en instalaciones para desarrollar estrategias preventivas y de mitigación específicas.",
    icon: "ri-search-eye-line",
    normativa: "LGPC y Reglamentos",
    duration: "5-10 días"
  },
  {
    id: 2,
    title: "Programa Interno de Protección Civil (PIPC)",
    description: "Desarrollo de programas personalizados según nivel de riesgo: bajo, medio y alto. Incluye procedimientos, organización, recursos y sistemas de alerta para la gestión integral de emergencias.",
    icon: "ri-file-shield-line",
    normativa: "Ley General de PC",
    duration: "2-4 semanas"
  },
  {
    id: 3,
    title: "Cursos de Brigadas de Protección Civil",
    description: "Capacitación especializada en las 4 brigadas fundamentales: Primeros Auxilios, Búsqueda y Rescate, Prevención y Combate de Incendios, y Evacuación de Inmuebles. Certificación oficial incluida.",
    icon: "ri-graduation-cap-line",
    normativa: "Certificación oficial",
    duration: "3-5 días"
  },
  {
    id: 4,
    title: "Conformación de Brigadas",
    description: "Selección, organización y estructuración de brigadas de protección civil. Definimos roles, responsabilidades, cadena de mando y protocolos de activación para respuesta efectiva ante emergencias.",
    icon: "ri-team-line",
    normativa: "Estándares nacionales",
    duration: "1-2 semanas"
  }
];
---

<section id="servicios" class="py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <!-- Header -->
      <div class="text-center mb-16 fade-in-section">
        <div class="inline-flex items-center bg-civil-600/10 border border-civil-600/20 rounded-full px-4 py-2 mb-6">
          <i class="ri-shield-check-line text-civil-600 mr-2"></i>
          <span class="text-civil-600 font-medium text-sm">Servicios Especializados</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-civil-600 mb-6">
          Servicios de Protección Civil
        </h2>
        <p class="text-lg text-neutral-700 max-w-3xl mx-auto leading-relaxed">
          Ofrecemos servicios integrales en protección civil: análisis de riesgos, programas internos, capacitación de brigadas y conformación de equipos de respuesta para garantizar la seguridad de tu organización.
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="services-grid">
        {services.map((service, index) => (
          <div 
            class={`service-card fade-in-section bg-neutral-100 rounded-xl shadow-lg border border-neutral-600 hover:border-civil-600/30 transition-all duration-300 hover:shadow-xl transform hover:-translate-y-2 overflow-hidden`}
            style={`animation-delay: ${(index % 4) * 100}ms`}
          >
            <!-- Card Header -->
            <div class="p-6 pb-4">
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 bg-civil-600/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class={`${service.icon} text-civil-600 text-xl`}></i>
                </div>
              </div>

              <h3 class="text-lg font-bold text-neutral-900 mb-3 leading-tight">
                {service.title}
              </h3>
              
              <p class="text-neutral-600 text-sm leading-relaxed mb-4">
                {service.description}
              </p>

              <!-- Service Details for PIPC -->
              {service.id === 2 && (
                <div class="mb-4">
                  <h4 class="text-sm font-semibold text-neutral-800 mb-2">Niveles de Riesgo:</h4>
                  <div class="space-y-1">
                    <div class="flex items-center text-xs text-neutral-600">
                      <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                      <span>Riesgo Bajo</span>
                    </div>
                    <div class="flex items-center text-xs text-neutral-600">
                      <div class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></div>
                      <span>Riesgo Medio</span>
                    </div>
                    <div class="flex items-center text-xs text-neutral-600">
                      <div class="w-2 h-2 bg-civil-500 rounded-full mr-2"></div>
                      <span>Riesgo Alto</span>
                    </div>
                  </div>
                </div>
              )}

              <!-- Service Details for Brigades Training -->
              {service.id === 3 && (
                <div class="mb-4">
                  <h4 class="text-sm font-semibold text-neutral-800 mb-2">Especialidades:</h4>
                  <div class="grid grid-cols-2 gap-1">
                    <div class="flex items-center text-xs text-neutral-600">
                      <i class="ri-heart-pulse-line text-civil-500 mr-1"></i>
                      <span>Primeros Auxilios</span>
                    </div>
                    <div class="flex items-center text-xs text-neutral-600">
                      <i class="ri-search-line text-blue-500 mr-1"></i>
                      <span>Búsqueda y Rescate</span>
                    </div>
                    <div class="flex items-center text-xs text-neutral-600">
                      <i class="ri-fire-line text-orange-500 mr-1"></i>
                      <span>Combate de Incendios</span>
                    </div>
                    <div class="flex items-center text-xs text-neutral-600">
                      <i class="ri-door-open-line text-green-500 mr-1"></i>
                      <span>Evacuación</span>
                    </div>
                  </div>
                </div>
              )}
            </div>

            <!-- Card Footer -->
            <div class="px-6 pb-6">
              <div class="space-y-2 mb-4">
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-bookmark-line mr-2"></i>
                  <span><strong>Marco Legal:</strong> {service.normativa}</span>
                </div>
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-time-line mr-2"></i>
                  <span><strong>Duración:</strong> {service.duration}</span>
                </div>
              </div>

              <button class="w-full bg-civil-600/5 hover:bg-civil-600 hover:text-white text-civil-600 font-medium py-2 px-4 rounded-lg transition-all duration-300 text-sm">
                Solicitar Información
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="mt-16 text-center fade-in-section" style="animation-delay: 800ms">
        <div class="bg-gradient-to-br from-civil-600/50 to-civil-700/90 rounded-2xl p-8 lg:p-12">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">
            ¿Necesitas implementar un programa de protección civil?
          </h3>
          <p class="text-civil-50 mb-6 max-w-2xl mx-auto">
            Nuestro equipo de especialistas certificados en protección civil puede desarrollar e implementar un programa integral adaptado a las necesidades específicas de tu organización.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button text="Solicitar evaluación" href="#contacto" variant="fill" palette="civil" icon="ri-arrow-right-line" />
            <Button text="Llamar ahora" href="tel:+521234567890" variant="outline" palette="civil" icon="ri-phone-line" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  // Service card click handlers
  document.addEventListener('DOMContentLoaded', () => {
    const serviceButtons = document.querySelectorAll('.service-card button');
    serviceButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        // Scroll to contact section
        document.getElementById('contacto')?.scrollIntoView({ 
          behavior: 'smooth' 
        });
      });
    });
  });
</script>