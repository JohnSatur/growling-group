---
---

<section class="py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16 fade-in-section">
        <h2 class="text-3xl md:text-4xl font-bold text-cardinal mb-4">
          Misión y Visión
        </h2>
        <p class="text-lg text-neutral-600 max-w-3xl mx-auto">
          Nuestros principios fundamentales que guían cada decisión y acción en Growling Group.
        </p>
      </div>

      <!-- Mission and Vision Cards -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Mission Card -->
        <div class="fade-in-section group" style="animation-delay: 200ms">
          <div class="relative h-full bg-neutral-100 rounded-2xl p-8 lg:p-10 border border-neutral-900 transition-all duration-300 hover:shadow-xl">
            <!-- Icon -->
            <div class="absolute -top-6 left-8">
              <div class="w-12 h-12 bg-neutral-900 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                <i class="ri-crosshair-fill text-cardinal text-xl"></i>
              </div>
            </div>
            
            <!-- Content -->
            <div class="pt-8">
              <h3 class="text-2xl lg:text-3xl font-bold text-neutral-900 mb-6">
                Nuestra Misión
              </h3>
              <p class="text-neutral-700 text-lg leading-relaxed">
                Brindar soluciones integrales en seguridad industrial, higiene laboral, gestión ambiental y protección contra incendios, asegurando el cumplimiento normativo y la mejora continua de los procesos de nuestros clientes, mediante asesoría especializada, tecnología de vanguardia y un enfoque comprometido con la protección de las personas, los bienes y el medio ambiente.
              </p>
            </div>

            <!-- Decorative Element -->
            <div class="absolute bottom-4 right-4 opacity-10 group-hover:opacity-20 transition-opacity duration-300">
              <i class="ri-compass-3-line text-cardinal text-6xl"></i>
            </div>
          </div>
        </div>

        <!-- Vision Card -->
        <div class="fade-in-section group" style="animation-delay: 400ms">
          <div class="relative h-full bg-neutral-100 rounded-2xl p-8 lg:p-10 border border-neutral-900 transition-all duration-300 hover:shadow-xl">
            <!-- Icon -->
            <div class="absolute -top-6 left-8">
              <div class="w-12 h-12 bg-neutral-800 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                <i class="ri-eye-line text-cardinal text-xl"></i>
              </div>
            </div>
            
            <!-- Content -->
            <div class="pt-8">
              <h3 class="text-2xl lg:text-3xl font-bold text-neutral-900 mb-6">
                Nuestra Visión
              </h3>
              <p class="text-neutral-700 text-lg leading-relaxed">
                Ser una empresa líder y referente nacional en consultoría, servicios técnicos y operativos en materia de seguridad, salud ocupacional y medio ambiente, distinguiéndonos por la calidad de nuestros servicios, la confianza de nuestros clientes y la innovación permanente de nuestras soluciones.
              </p>
            </div>

            <!-- Decorative Element -->
            <div class="absolute bottom-4 right-4 opacity-10 group-hover:opacity-20 transition-opacity duration-300">
              <i class="ri-glasses-fill text-cardinal text-6xl"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
