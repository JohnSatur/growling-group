---
import { getCollection } from 'astro:content';
import BlogPostCard from '@components/ui/BlogPostCard.astro';
import Button from '@components/ui/Button.astro';
import blogHeroImage from '@images/logo.png';

// Obtener todos los posts y ordenarlos por fecha (más recientes primero)
const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// Formatear fecha para mostrar
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('es-ES', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(date);
};

// Mapear los posts a la estructura que espera el componente
const blogPosts = latestPosts.map((post) => ({
  title: post.data.title,
  excerpt: post.data.description,
  date: formatDate(post.data.pubDate),
  image: post.data.image || blogHeroImage,
  link: `/blog/${post.data.slug}`
}));
---

<section id="blog" class="py-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-cardinal mb-4">Últimos Artículos del Blog</h2>
      <p class="text-lg text-neutral-700 max-w-3xl mx-auto">
        Manténgase actualizado con las últimas tendencias y conocimientos en nuestras áreas de especialización.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {blogPosts.map((post) => (
        <BlogPostCard
          image={post.image}
          title={post.title}
          excerpt={post.excerpt}
          date={post.date}
          link={post.link}
        />
      ))}
    </div>
    
    <div class="text-center mt-12">
      <Button text="Ir al Blog" href="/blog" variant="outline" icon="ri-news-fill" />
    </div>
  </div>
</section>
