---
import Button from "@components/ui/Button.astro";

const services = [
  {
    id: 1,
    title: "Brigadas de protección civil",
    description: "Formación integral de brigadas para la prevención, respuesta y control de emergencias en centros de trabajo, conforme a la normatividad vigente.",
    icon: "ri-shield-cross-line",
    detail: "Modalidad presencial y mixta",
    duration: "8-16 horas"
  },
  {
    id: 2,
    title: "Seguridad e higiene industrial",
    description: "Capacitación especializada en seguridad y salud laboral para la prevención de riesgos y cumplimiento normativo. Consulta nuestro catálogo.",
    icon: "ri-brush-ai-fill",
    detail: "Catálogo disponible",
    duration: "Variable"
  },
  {
    id: 3,
    title: "Estándares red CONOCER",
    description: "Certificación de competencias laborales bajo estándares oficiales de la Red CONOCER, avalados por la SEP.",
    icon: "ri-medal-line",
    detail: "Certificación oficial",
    duration: "De acuerdo al estándar"
  },
  {
    id: 4,
    title: "Titulación por experiencia",
    description: "Proceso de titulación profesional mediante la validación de experiencia laboral y competencias adquiridas en el campo.",
    icon: "ri-graduation-cap-line",
    detail: "Reconocimiento SEP",
    duration: "Variable"
  },
  {
    id: 5,
    title: "Cumplimiento de programas de capacitación STPS",
    description: "Diseño, implementación y seguimiento de programas de capacitación alineados a los requerimientos de la STPS.",
    icon: "ri-briefcase-4-line",
    detail: "Programas personalizados",
    duration: "Según programa"
  }
];
---

<section id="servicios" class="py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <!-- Header -->
      <div class="text-center mb-16 fade-in-section">
        <div class="inline-flex items-center bg-capacitacion/10 border border-capacitacion/20 rounded-full px-4 py-2 mb-6">
          <i class="ri-book-open-line text-capacitacion mr-2"></i>
          <span class="text-capacitacion font-medium text-sm">Capacitación Certificada</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-capacitacion mb-6">
          Servicios de Capacitación y Certificación
        </h2>
        <p class="text-lg text-neutral-700 max-w-3xl mx-auto leading-relaxed">
          Ofrecemos programas de capacitación certificados, alineados a la normatividad nacional, para el desarrollo de competencias laborales, cumplimiento legal y profesionalización de tu equipo.
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
        {services.map((service, index) => (
          <div 
            class={`service-card fade-in-section bg-neutral-100 rounded-xl shadow-lg border border-neutral-600 hover:border-capacitacion/30 transition-all duration-300 hover:shadow-xl transform hover:-translate-y-2 overflow-hidden`}
            style={`animation-delay: ${(index % 6) * 100}ms`}
          >
            <!-- Card Header -->
            <div class="p-6 pb-4">
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 bg-capacitacion/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class={`${service.icon} text-capacitacion text-xl`}></i>
                </div>
                <span class="text-xs bg-neutral-100 text-neutral-600 px-2 py-1 rounded-full">
                  Capacitación
                </span>
              </div>

              <h3 class="text-lg font-bold text-neutral-900 mb-3 leading-tight">
                {service.title}
              </h3>
              
              <p class="text-neutral-600 text-sm leading-relaxed mb-4">
                {service.description}
              </p>
            </div>

            <!-- Card Footer -->
            <div class="px-6 pb-6">
              <div class="space-y-2 mb-4">
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-information-line mr-2"></i>
                  <span><strong>Detalle:</strong> {service.detail}</span>
                </div>
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-time-line mr-2"></i>
                  <span><strong>Duración:</strong> {service.duration}</span>
                </div>
              </div>

              <button class="w-full bg-capacitacion/5 hover:bg-capacitacion hover:text-white text-capacitacion font-medium py-2 px-4 rounded-lg transition-all duration-300 text-sm">
                Solicitar Información
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="mt-16 text-center fade-in-section" style="animation-delay: 800ms">
        <div class="bg-gradient-to-br from-capacitacion/50 to-capacitacion/90 rounded-2xl p-8 lg:p-12">
          <h3 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-4">
            ¿Buscas capacitación a la medida?
          </h3>
          <p class="text-neutral-800 mb-6 max-w-2xl mx-auto">
            Nuestro equipo de instructores certificados puede diseñar programas de formación y certificación adaptados a las necesidades de tu organización.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button text="Solicitar cotización" href="#contacto" variant="fill" palette="capacitacion" icon="ri-arrow-right-line" />
            <Button text="Llamar ahora" href="tel:+521234567890" variant="outline" palette="capacitacion" icon="ri-phone-line" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  // Service card click handlers
  document.addEventListener('DOMContentLoaded', () => {
    const serviceButtons = document.querySelectorAll('.service-card button');
    serviceButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        // Scroll to contact section
        document.getElementById('contacto')?.scrollIntoView({ 
          behavior: 'smooth' 
        });
      });
    });
  });
</script>
