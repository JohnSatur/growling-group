---
import Button from "@components/ui/Button.astro";

const services = [
  {
    id: 1,
    title: "Brigadas de Protección Civil",
    description: "Formación especializada en las 4 brigadas fundamentales: primeros auxilios, búsqueda y rescate, prevención y combate de incendios, y evacuación de inmuebles. Capacitación práctica y certificada para personal de respuesta a emergencias.",
    icon: "ri-shield-line",
    modalidad: "Presencial",
    duration: "40 horas"
  },
  {
    id: 2,
    title: "Seguridad e Higiene Industrial",
    description: "Amplio catálogo de cursos en seguridad ocupacional, uso de EPP, manejo de sustancias peligrosas, ergonomía y prevención de riesgos laborales. Programas adaptados a cada sector industrial y nivel de riesgo.",
    icon: "ri-brush-ai-fill",
    modalidad: "Consulta catálogo",
    duration: "Variable"
  },
  {
    id: 3,
    title: "Estándares Red Conocer",
    description: "Capacitación y evaluación en competencias laborales bajo estándares de la Red CONOCER. Certificación oficial de habilidades y conocimientos técnicos para diferentes sectores productivos.",
    icon: "ri-award-line",
    modalidad: "Evaluación y capacitación",
    duration: "Según estándar"
  },
  {
    id: 4,
    title: "Titulación por Experiencia",
    description: "Proceso de reconocimiento y certificación de competencias adquiridas a través de la experiencia laboral. Evaluación de saberes previos para obtener certificación oficial sin cursar programas completos.",
    icon: "ri-graduation-cap-line",
    modalidad: "Evaluación",
    duration: "2-4 semanas"
  },
  {
    id: 5,
    title: "Cumplimiento de Programas STPS",
    description: "Diseño e implementación de programas de capacitación obligatorios según la normativa STPS. Aseguramos el cumplimiento legal y el desarrollo continuo del capital humano en tu empresa.",
    icon: "ri-file-check-line",
    modalidad: "Integral",
    duration: "Anual"
  }
];
---

<section id="servicios" class="py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <!-- Header -->
      <div class="text-center mb-16 fade-in-section">
        <div class="inline-flex items-center bg-capacitacion/10 border border-capacitacion/20 rounded-full px-4 py-2 mb-6">
          <i class="ri-graduation-cap-line text-capacitacion mr-2"></i>
          <span class="text-capacitacion font-medium text-sm">Servicios Especializados</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-capacitacion mb-6">
          Servicios de Capacitación Certificada
        </h2>
        <p class="text-lg text-neutral-700 max-w-3xl mx-auto leading-relaxed">
          Ofrecemos 5 servicios especializados de capacitación certificada: brigadas de protección civil, seguridad e higiene industrial, estándares Red Conocer, titulación por experiencia y cumplimiento normativo STPS.
        </p>
      </div>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
        {services.map((service, index) => (
          <div 
            class={`service-card fade-in-section bg-neutral-100 rounded-xl shadow-lg border border-neutral-600 hover:border-capacitacion/30 transition-all duration-300 hover:shadow-xl transform hover:-translate-y-2 overflow-hidden`}
            style={`animation-delay: ${(index % 5) * 100}ms`}
          >
            <!-- Card Header -->
            <div class="p-6 pb-4">
              <div class="flex items-start justify-between mb-4">
                <div class="w-12 h-12 bg-capacitacion/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class={`${service.icon} text-capacitacion text-xl`}></i>
                </div>
              </div>

              <h3 class="text-lg font-bold text-neutral-900 mb-3 leading-tight">
                {service.title}
              </h3>
              
              <p class="text-neutral-600 text-sm leading-relaxed mb-4">
                {service.description}
              </p>
            </div>

            <!-- Card Footer -->
            <div class="px-6 pb-6">
              <div class="space-y-2 mb-4">
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-presentation-line mr-2"></i>
                  <span><strong>Modalidad:</strong> {service.modalidad}</span>
                </div>
                <div class="flex items-center text-xs text-neutral-500">
                  <i class="ri-time-line mr-2"></i>
                  <span><strong>Duración:</strong> {service.duration}</span>
                </div>
              </div>

              <button class="w-full bg-capacitacion/5 hover:bg-capacitacion hover:text-white text-capacitacion font-medium py-2 px-4 rounded-lg transition-all duration-300 text-sm">
                Solicitar Información
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="mt-16 text-center fade-in-section" style="animation-delay: 800ms">
        <div class="bg-gradient-to-br from-capacitacion/50 to-capacitacion/90 rounded-2xl p-8 lg:p-12">
          <h3 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-4">
            ¿Necesitas capacitación personalizada?
          </h3>
          <p class="text-neutral-800 mb-6 max-w-2xl mx-auto">
            Nuestro equipo de instructores certificados puede adaptar nuestros programas de capacitación a las necesidades específicas de tu empresa y sector.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button text="Solicitar catálogo" href="#contacto" variant="fill" palette="capacitacion" icon="ri-arrow-right-line" />
            <Button text="Llamar ahora" href="tel:+521234567890" variant="outline" palette="capacitacion" icon="ri-phone-line" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  // Service card click handlers
  document.addEventListener('DOMContentLoaded', () => {
    const serviceButtons = document.querySelectorAll('.service-card button');
    serviceButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        // Scroll to contact section
        document.getElementById('contacto')?.scrollIntoView({ 
          behavior: 'smooth' 
        });
      });
    });
  });
</script>
