---
import Button from '@components/ui/Button.astro';
import Logo from '@components/ui/Logo.astro';
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout>
  <main class="min-h-screen relative overflow-hidden bg-background">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
      <!-- Background Image -->
      <div 
        class="w-full h-full bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop');"
      ></div>
      
      <!-- Theme-aware Overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-neutral-900/80 via-neutral-900/70 to-neutral-800/80 dark:from-neutral-900/85 dark:via-neutral-900/75 dark:to-neutral-800/85"></div>
      
      <!-- Subtle Pattern Overlay -->
      <div class="absolute inset-0 opacity-10" 
        style="background-image: radial-gradient(circle at 1px 1px, color-mix(in srgb, var(--contrast) 15%, transparent) 1px, transparent 0); background-size: 20px 20px;"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-4 sm:px-6 lg:px-8 text-center">
      
      <!-- Logo -->
      <div class="mb-8 animate-fade-in">
        <a href="/" class="inline-block">
          <Logo palette="cardinal" variant="isotipo" class="w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 filter drop-shadow-lg" />
        </a>
      </div>

      <!-- 404 Text -->
      <div class="mb-8 animate-fade-in-up" style="animation-delay: 200ms;">
        <h1 class="text-8xl sm:text-9xl lg:text-[12rem] font-black text-contrast leading-none tracking-tight mb-4">
          404
        </h1>
        <div class="w-24 h-1 bg-cardinal mx-auto rounded-full mb-6"></div>
      </div>

      <!-- Error Message -->
      <div class="mb-12 animate-fade-in-up max-w-2xl" style="animation-delay: 400ms;">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-contrast mb-4 drop-shadow-lg">
          Página no encontrada
        </h2>
        <p class="text-lg sm:text-xl text-neutral-700 dark:text-neutral-300 leading-relaxed drop-shadow-md">
          Lo sentimos, la página que buscas no existe o ha sido movida. 
          Te invitamos a regresar al inicio y explorar nuestros servicios.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 600ms;">
        <Button 
          text="Ir al Inicio"
          href="/"
          variant="fill"
          palette="cardinal"
          icon="ri-home-line"
          iconPosition="left"
          class="shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        />
        <Button 
          text="Ver Servicios"
          href="/#servicios"
          variant="outline"
          palette="cardinal"
          icon="ri-service-line"
          iconPosition="left"
          class="shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        />
      </div>

      <!-- Additional Help -->
      <div class="mt-16 animate-fade-in-up" style="animation-delay: 800ms;">
        <p class="text-neutral-600 dark:text-neutral-400 text-sm mb-4">
          ¿Necesitas ayuda? Contáctanos directamente
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-sm">
          <a 
            href="tel:+521234567890" 
            class="flex items-center text-neutral-700 dark:text-neutral-300 hover:text-cardinal transition-colors duration-300 group"
          >
            <i class="ri-phone-line mr-2 text-lg group-hover:animate-pulse"></i>
            <span>+52 123 456 7890</span>
          </a>
          <a 
            href="mailto:contacto@tuempresa.com" 
            class="flex items-center text-neutral-700 dark:text-neutral-300 hover:text-cardinal transition-colors duration-300 group"
          >
            <i class="ri-mail-line mr-2 text-lg group-hover:animate-pulse"></i>
            <span>contacto@tuempresa.com</span>
          </a>
          <a 
            href="https://wa.me/521234567890" 
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center text-neutral-700 dark:text-neutral-300 hover:text-green-400 transition-colors duration-300 group"
          >
            <i class="ri-whatsapp-line mr-2 text-lg group-hover:animate-pulse"></i>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Floating Elements for Visual Interest -->
    <div class="absolute top-20 left-10 w-2 h-2 bg-cardinal rounded-full opacity-60 animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-40 right-20 w-3 h-3 bg-neutral-800 dark:bg-neutral-200 rounded-full opacity-40 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-32 left-20 w-1 h-1 bg-cardinal rounded-full opacity-80 animate-pulse" style="animation-delay: 1.5s;"></div>
    <div class="absolute bottom-20 right-10 w-2 h-2 bg-neutral-800 dark:bg-neutral-200 rounded-full opacity-50 animate-pulse" style="animation-delay: 2.5s;"></div>
  </main>
</MainLayout>

<style>
  /* Custom animations */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
    opacity: 0;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  /* Ensure full height on mobile */
  main {
    min-height: 100vh;
    min-height: 100dvh; /* Dynamic viewport height for mobile */
  }

  /* Custom text shadow for better readability */
  h1 {
    text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
  }

  h2 {
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  p {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  /* Responsive font sizes for 404 */
  @media (max-width: 640px) {
    h1 {
      font-size: 6rem;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 5rem;
    }
  }

  /* Hover effects for floating elements */
  .absolute.animate-pulse:hover {
    transform: scale(1.5);
    transition: transform 0.3s ease;
  }
</style>

<script type="module">
  // Add some interactive behavior
  document.addEventListener('DOMContentLoaded', () => {
    // Add parallax effect to background on scroll (subtle)
    const background = document.querySelector('main > div');
    
    window.addEventListener('scroll', () => {
      const scrolled = window.pageYOffset;
      const rate = scrolled * -0.5;
      
      if (background) {
        background.style.transform = `translateY(${rate}px)`;
      }
    });

    // Add click effect to floating elements
    const floatingElements = document.querySelectorAll('.absolute.animate-pulse');
    floatingElements.forEach(element => {
      element.addEventListener('click', () => {
        element.style.animation = 'none';
        element.offsetHeight; // Trigger reflow
        element.style.animation = 'pulse 1s ease-in-out infinite';
      });
    });

    // Keyboard navigation enhancement
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const focusedElement = document.activeElement;
        if (focusedElement && focusedElement.tagName === 'A') {
          focusedElement.click();
        }
      }
    });
  });
</script>
