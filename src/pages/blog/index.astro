---
import { getCollection } from 'astro:content';
import MainLayout from '@layouts/MainLayout.astro';
import BlogHero from '@components/sections/blog/HeroSection.astro';
import BlogCard from '@components/ui/BlogCard.astro';
// import CategoryCard from '@components/ui/CategoryCard.astro';
import Button from '@components/ui/Button.astro';

// Obtener todas las colecciones
const allPosts = await getCollection('posts');

const allCategories = await getCollection('categories');

// Ordenar posts por fecha (más recientes primero)
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Obtener posts destacados (los 3 más recientes)
const featuredPosts = sortedPosts.slice(0, 3);

// Obtener posts recientes (siguientes 6)
const recentPosts = sortedPosts.slice(3, 9);

// Contar posts por categoría
const postsByCategory = allCategories.map(category => {
  const postCount = allPosts.filter(post => 
    post.data.category?.id === category.id
  ).length;
  
  return {
    category,
    postCount
  };
}).filter(item => item.postCount > 0);
---

<MainLayout 
  title="Blog - Tu Empresa | Artículos Especializados"
>
  <!-- Hero Section -->
  <BlogHero />

  <!-- Featured Posts Section -->
  {featuredPosts.length > 0 && (
    <section id="posts-destacados" class="py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <div class="inline-flex items-center bg-cardinal/10 border border-cardinal/20 rounded-full px-4 py-2 mb-6">
            <i class="ri-star-line text-cardinal mr-2"></i>
            <span class="text-cardinal font-medium text-sm">Destacados</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-950 mb-4">
            Artículos Destacados
          </h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
            Los artículos más relevantes y actuales de nuestro blog
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {featuredPosts.map((post, index) => (
            <BlogCard 
              post={post} 
              featured={index === 0}
              class="fade-in-section"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Posts Section -->
  <section id="ultimos-posts" class="py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center bg-cardinal-600/10 border border-cardinal-600/20 rounded-full px-4 py-2 mb-6">
          <i class="ri-time-line text-cardinal-600 mr-2"></i>
          <span class="text-cardinal-600 font-medium text-sm">Recientes</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Últimos Artículos
        </h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
          Mantente al día con nuestras últimas publicaciones y análisis especializados
        </p>
      </div>

      {recentPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
          {recentPosts.map((post, index) => (
            <BlogCard 
              post={post}
              class="fade-in-section"
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="w-24 h-24 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="ri-article-line text-neutral-400 text-3xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-neutral-700 mb-2">No hay artículos disponibles</h3>
