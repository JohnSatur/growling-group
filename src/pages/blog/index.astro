        </div>
      )}

      {sortedPosts.length > 9 && (
        <div class="text-center">
          <Button 
            text="Ver Todos los Artículos"
            href="/blog/todos"
            variant="outline"
            palette="cardinal"
            icon="ri-arrow-right-line"
          />
        </div>
      )}
    </div>
  </section>

