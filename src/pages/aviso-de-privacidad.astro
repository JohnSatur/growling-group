---
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout title="Aviso de Privacidad - Growling Group">
  <main>
    <!-- Header Section -->
    <section class="min-h-[60vh] bg-gradient-to-br from-cardinal/60 to-cardinal/40 py-20 flex items-center">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center bg-cardinal/10 border border-cardinal/20 rounded-full px-4 py-2 mb-6">
            <i class="ri-shield-check-line text-cardinal mr-2"></i>
            <span class="text-cardinal font-medium text-sm">Protección de Datos</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-6">
            Aviso de Privacidad
          </h1>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
            En Tu Empresa valoramos y respetamos tu privacidad. Este aviso describe cómo recopilamos, 
            utilizamos y protegemos tu información personal.
          </p>
          <div class="mt-8 text-sm text-neutral-500">
            <p>Última actualización: <span class="font-semibold">18 de julio de 2025</span></p>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="prose prose-lg max-w-none">
            
            <!-- Responsable -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-building-line text-cardinal mr-3"></i>
                Responsable del Tratamiento
              </h2>
              <div class="bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                <p class="text-neutral-700 mb-4">
                  <strong>Growling Group</strong> con domicilio en Veracruz, México, es el responsable del uso y protección de sus datos personales.
                </p>
                <div class="grid md:grid-cols-2 gap-4 text-sm text-neutral-700">
                  <div>
                    <p><strong>Email:</strong> contacto@growlinggroup.com</p>
                    <p><strong>Teléfono:</strong> +52 (228) 100 6400</p>
                  </div>
                  <div>
                    <p><strong>Ubicación:</strong> Xalapa, Veracruz, México</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Datos que recopilamos -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-database-line text-cardinal mr-3"></i>
                Datos Personales que Recopilamos
              </h2>
              <p class="text-neutral-700 mb-6">
                Recopilamos los siguientes tipos de datos personales:
              </p>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                  <h3 class="font-semibold text-neutral-900 mb-3 flex items-center">
                    <i class="ri-user-line mr-2"></i>
                    Datos de Identificación
                  </h3>
                  <ul class="text-sm text-neutral-800 space-y-1">
                    <li>• Nombre completo</li>
                    <li>• Correo electrónico</li>
                    <li>• Número telefónico</li>
                    <li>• Empresa u organización</li>
                  </ul>
                </div>
                
                <div class="bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                  <h3 class="font-semibold text-neutral-900 mb-3 flex items-center">
                    <i class="ri-briefcase-line mr-2"></i>
                    Datos Profesionales
                  </h3>
                  <ul class="text-sm text-neutral-800 space-y-1">
                    <li>• Cargo o puesto</li>
                    <li>• Sector industrial</li>
                    <li>• Servicios de interés</li>
                    <li>• Historial de servicios</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Finalidades -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-target-line text-cardinal mr-3"></i>
                Finalidades del Tratamiento
              </h2>
              <p class="text-neutral-700 mb-6">
                Utilizamos sus datos personales para las siguientes finalidades:
              </p>
              
              <div class="space-y-4">
                <div class="bg-cardinal/5 rounded-lg p-4 border-l-4 border-cardinal">
                  <h3 class="font-semibold text-cardinal mb-2">Finalidades Primarias (Necesarias)</h3>
                  <ul class="text-neutral-700 text-sm space-y-1">
                    <li>• Proporcionar servicios de consultoría empresarial</li>
                    <li>• Procesar solicitudes de cotización</li>
                    <li>• Comunicación relacionada con servicios contratados</li>
                    <li>• Cumplimiento de obligaciones contractuales</li>
                  </ul>
                </div>
                
                <div class="bg-blue/5 rounded-lg p-4 border-l-4 border-drones-500">
                  <h3 class="font-semibold text-drones-700 mb-2">Finalidades Secundarias (Opcionales)</h3>
                  <ul class="text-neutral-700 text-sm space-y-1">
                    <li>• Envío de información promocional y newsletters</li>
                    <li>• Invitaciones a eventos y capacitaciones</li>
                    <li>• Estudios de mercado y mejora de servicios</li>
                    <li>• Comunicación de nuevos servicios</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Derechos ARCO -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-shield-user-line text-cardinal mr-3"></i>
                Sus Derechos (ARCO)
              </h2>
              <p class="text-neutral-700 mb-6">
                Usted tiene derecho a:
              </p>
              
              <div class="grid md:grid-cols-2 gap-4">
                <div class="bg-civil-50 rounded-lg p-4 border border-civil-200">
                  <h3 class="font-semibold text-civil-900 mb-2 flex items-center">
                    <i class="ri-eye-line mr-2"></i>
                    Acceder
                  </h3>
                  <p class="text-sm text-civil-800">Conocer qué datos personales tenemos de usted</p>
                </div>
                
                <div class="bg-capacitacion-50 rounded-lg p-4 border border-capacitacion-200">
                  <h3 class="font-semibold text-capacitacion-900 mb-2 flex items-center">
                    <i class="ri-edit-line mr-2"></i>
                    Rectificar
                  </h3>
                  <p class="text-sm text-capacitacion-800">Solicitar la corrección de datos inexactos</p>
                </div>
                
                <div class="bg-ambiental-50 rounded-lg p-4 border border-ambiental-200">
                  <h3 class="font-semibold text-ambiental-900 mb-2 flex items-center">
                    <i class="ri-delete-bin-line mr-2"></i>
                    Cancelar
                  </h3>
                  <p class="text-sm text-ambiental-800">Solicitar que dejemos de usar sus datos</p>
                </div>
                
                <div class="bg-calderas-50 rounded-lg p-4 border border-calderas-200">
                  <h3 class="font-semibold text-calderas-900 mb-2 flex items-center">
                    <i class="ri-forbid-line mr-2"></i>
                    Oponerse
                  </h3>
                  <p class="text-sm text-calderas-800">Oponerse al tratamiento de sus datos</p>
                </div>
              </div>
              
              <div class="mt-6 bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                <h3 class="font-semibold text-neutral-900 mb-3">¿Cómo ejercer sus derechos?</h3>
                <p class="text-neutral-700 text-sm mb-3">
                  Para ejercer cualquiera de estos derechos, puede contactarnos a través de:
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                  <a href="mailto:privacidad@growlinggroup.com" class="inline-flex items-center text-cardinal hover:text-cardinal/80 transition-colors">
                    <i class="ri-mail-line mr-2"></i>
                    privacidad@growlinggroup.com
                  </a>
                  <a href="tel:+522286143923" class="inline-flex items-center text-cardinal hover:text-cardinal/80 transition-colors">
                    <i class="ri-phone-line mr-2"></i>
                    +52 (228) 614 3923
                  </a>
                </div>
              </div>
            </div>

            <!-- Seguridad -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-lock-line text-cardinal mr-3"></i>
                Medidas de Seguridad
              </h2>
              <div class="bg-gradient-to-r from-cardinal/5 to-cardinal/10 rounded-lg p-6 border border-cardinal/20">
                <p class="text-neutral-700 mb-4">
                  Implementamos medidas de seguridad físicas, técnicas y administrativas para proteger sus datos personales:
                </p>
                <div class="grid md:grid-cols-3 gap-4">
                  <div class="text-center">
                    <i class="ri-shield-check-line text-3xl text-cardinal mb-2"></i>
                    <h4 class="font-semibold text-neutral-900 mb-1">Encriptación</h4>
                    <p class="text-sm text-neutral-600">Datos protegidos con encriptación SSL</p>
                  </div>
                  <div class="text-center">
                    <i class="ri-server-line text-3xl text-cardinal mb-2"></i>
                    <h4 class="font-semibold text-neutral-900 mb-1">Servidores Seguros</h4>
                    <p class="text-sm text-neutral-600">Almacenamiento en servidores certificados</p>
                  </div>
                  <div class="text-center">
                    <i class="ri-user-settings-line text-3xl text-cardinal mb-2"></i>
                    <h4 class="font-semibold text-neutral-900 mb-1">Acceso Controlado</h4>
                    <p class="text-sm text-neutral-600">Solo personal autorizado accede a los datos</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Transferencias -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-share-line text-cardinal mr-3"></i>
                Transferencias de Datos
              </h2>
              <div class="bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                <p class="text-neutral-700 mb-4">
                  Sus datos personales pueden ser transferidos a:
                </p>
                <ul class="text-neutral-700 space-y-2">
                  <li class="flex items-start">
                    <i class="ri-check-line text-cardinal mr-2 mt-1"></i>
                    <span>Proveedores de servicios tecnológicos (hosting, email marketing)</span>
                  </li>
                  <li class="flex items-start">
                    <i class="ri-check-line text-cardinal mr-2 mt-1"></i>
                    <span>Autoridades competentes cuando sea requerido por ley</span>
                  </li>
                  <li class="flex items-start">
                    <i class="ri-check-line text-cardinal mr-2 mt-1"></i>
                    <span>Socios comerciales para la prestación de servicios conjuntos</span>
                  </li>
                </ul>
                <p class="text-sm text-neutral-600 mt-4">
                  <strong>Nota:</strong> Todas las transferencias se realizan bajo estrictas medidas de seguridad y confidencialidad.
                </p>
              </div>
            </div>

            <!-- Cambios al aviso -->
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-refresh-line text-cardinal mr-3"></i>
                Cambios al Aviso de Privacidad
              </h2>
              <div class="bg-neutral-50 rounded-lg p-6 border border-neutral-200">
                <p class="text-neutral-700 mb-4">
                  Nos reservamos el derecho de efectuar cambios o actualizaciones a este Aviso de Privacidad. 
                  Los cambios serán comunicados a través de:
                </p>
                <ul class="text-neutral-700 space-y-2">
                  <li class="flex items-center">
                    <i class="ri-global-line text-cardinal mr-2"></i>
                    <span>Publicación en nuestro sitio web</span>
                  </li>
                  <li class="flex items-center">
                    <i class="ri-mail-line text-cardinal mr-2"></i>
                    <span>Notificación por correo electrónico</span>
                  </li>
                  <li class="flex items-center">
                    <i class="ri-phone-line text-cardinal mr-2"></i>
                    <span>Comunicación directa cuando sea necesario</span>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Contacto -->
            <div class="bg-gradient-to-br from-cardinal/10 to-cardinal/5 rounded-xl p-8 border border-cardinal/20">
              <h2 class="text-2xl font-bold text-neutral-900 mb-4 flex items-center">
                <i class="ri-customer-service-line text-cardinal mr-3"></i>
                ¿Tienes Dudas?
              </h2>
              <p class="text-neutral-700 mb-6">
                Si tienes preguntas sobre este Aviso de Privacidad o sobre el tratamiento de tus datos personales, 
                no dudes en contactarnos.
              </p>
              <div class="grid md:grid-cols-2 gap-4">
                <a href="mailto:privacidad@growlinggroup.com" class="flex items-center justify-center bg-background rounded-lg p-4 border border-cardinal/20 hover:border-cardinal/40 transition-colors group">
                  <i class="ri-mail-line text-cardinal mr-3 text-xl"></i>
                  <div>
                    <p class="font-semibold text-neutral-900 group-hover:text-cardinal transition-colors">Email</p>
                    <p class="text-sm text-neutral-600">privacidad@growlinggroup.com</p>
                  </div>
                </a>
                <a href="tel:+522286143923" class="flex items-center justify-center bg-background rounded-lg p-4 border border-cardinal/20 hover:border-cardinal/40 transition-colors group">
                  <i class="ri-phone-line text-cardinal mr-3 text-xl"></i>
                  <div>
                    <p class="font-semibold text-neutral-900 group-hover:text-cardinal transition-colors">Teléfono</p>
                    <p class="text-sm text-neutral-600">+52 (228) 614 3923</p>
                  </div>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .prose h2 {
    border-bottom: 2px solid #f3f4f6;
    padding-bottom: 0.5rem;
  }
  
  .prose ul {
    list-style: none;
    padding-left: 0;
  }
  
  .prose li {
    margin: 0.5rem 0;
  }
</style>
